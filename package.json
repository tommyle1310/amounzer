{
    "name":  "amounzer",
    "private":  true,
    "scripts":  {
                    "build":  "pnpm -r build",
                    "dev":  "pnpm -r --parallel dev",
                    "dev:api":  "pnpm --filter @amounzer/api dev",
                    "dev:web":  "pnpm --filter @amounzer/web dev",
                    "lint":  "pnpm -r lint",
                    "type-check":  "pnpm -r type-check",
                    "test":  "pnpm -r test",
                    "db:generate":  "pnpm --filter @amounzer/db generate",
                    "db:migrate":  "pnpm --filter @amounzer/db migrate",
                    "db:seed":  "pnpm --filter @amounzer/db seed",
                    "db:studio":  "pnpm --filter @amounzer/db studio",
                    "format":  "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
                    "format:check":  "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
                },
    "engines":  {
                    "node":  "\u003e=20.0.0"
                },
    "pnpm":  {
                 "onlyBuiltDependencies":  [
                                               "@prisma/client",
                                               "@prisma/engines",
                                               "prisma",
                                               "bcrypt",
                                               "esbuild",
                                               "sharp",
                                               "@nestjs/core"
                                           ]
             }
}
